# 数据库
POSTGRES_DB=multica
POSTGRES_USER=multica
POSTGRES_PASSWORD=multica
POSTGRES_PORT=5432
DATABASE_URL=postgres://multica:multica@localhost:5432/multica?sslmode=disable
# 可选：pgxpool 连接池调优。默认每个实例 25 / 5，通常无需修改。
# 也可以在 DATABASE_URL 的 query 参数中设置 pool_max_conns /
# pool_min_conns；下面的环境变量优先级高于 URL 参数。
# DATABASE_MAX_CONNS=25
# DATABASE_MIN_CONNS=5

# 服务端
# APP_ENV 用于启用生产环境安全检查；有效语义值：production / staging / development。
# 代码里只对 APP_ENV=production 做强校验；analytics 会把 production/prod、
# staging/stage、development/dev/test/local 规范化为 production/staging/dev。
# Docker 自托管默认会将 APP_ENV 固定为 "production"。本地开发可留空。
# 完整登录配置见 SELF_HOSTING.md。
APP_ENV=production
# 可选：本地/测试快捷验证码。默认留空，表示没有固定验证码。
# 未配置 RESEND_API_KEY 时，生成的验证码会打印到 stdout。
# 如需稳定的本地自动化，可设置 6 位数字（例如 888888），并保持 APP_ENV
# 非 production。APP_ENV=production 时该配置会被忽略。
MULTICA_DEV_VERIFICATION_CODE=
PORT=8080
# LOG_LEVEL 默认 debug；可选值：debug / info / warn / warning / error。
# 生产环境通常建议 info；排查问题时临时改 debug。
# LOG_LEVEL=info
# Prometheus 指标默认关闭。启用时建议绑定到 loopback，除非你已通过私有网络、
# allowlist 或代理认证保护该监听地址。不要把该端点暴露到公网 app/API 入口。
# HTTP 请求指标只有在该监听器启用后才会开始累计。
# METRICS_ADDR=127.0.0.1:9090
JWT_SECRET=a0ee366cca46eb8e28f79fa4d7f4c1160ace234f44ca8ff376c002d65cd50e89

# Redis 可选。留空时使用内存 hub，只适合单 API 节点。
# 多节点部署或需要跨进程实时广播时设置 REDIS_URL（例如 redis://localhost:6379/0）。
# REDIS_URL=
# 设置 REDIS_URL 后，实时 relay 默认使用 sharded 模式。
# REALTIME_RELAY_MODE 可选值：sharded（默认）/ dual（双写迁移）/ legacy（旧模式）。
# 下面几个 sharded 参数的代码默认值分别是：8、100000、128、5s。
# REALTIME_RELAY_MODE=sharded
# REALTIME_RELAY_SHARDS=8
# REALTIME_RELAY_STREAM_MAXLEN=100000
# REALTIME_RELAY_XREAD_COUNT=128
# REALTIME_RELAY_XREAD_BLOCK=5s

# Daemon / CLI
# MULTICA_SERVER_URL 支持 ws/wss/http/https；代码会把 ws(s) 规范化为 http(s) base URL。
MULTICA_SERVER_URL=ws://localhost:8080/ws
MULTICA_APP_URL=http://localhost:3000
MULTICA_WORKSPACE_ID=
# 留空时 daemon 会在本机 profile 目录持久化一个 UUID；只有嵌入式/测试环境才建议固定。
MULTICA_DAEMON_ID=
# 默认取系统 hostname。
MULTICA_DAEMON_DEVICE_NAME=
# Runtime 名称默认 "Local Agent"；显示在设置页的运行时列表中。
# MULTICA_AGENT_RUNTIME_NAME=Local Agent
# 工作区执行目录默认 ~/multica_workspaces；命名 profile 会变为 ~/multica_workspaces_<profile>。
# MULTICA_WORKSPACES_ROOT=
# 轮询间隔代码默认 30s；本地模板用 3s，让开发环境响应更快。
MULTICA_DAEMON_POLL_INTERVAL=3s
# 心跳间隔代码默认 15s。
MULTICA_DAEMON_HEARTBEAT_INTERVAL=15s
# 单 daemon 最大并发 task 数默认 20；小机器可下调。
# MULTICA_DAEMON_MAX_CONCURRENT_TASKS=20
# 单个 agent 执行超时默认 2h。
# MULTICA_AGENT_TIMEOUT=2h
# 仅 Codex：语义无进展超时默认 10m。
# MULTICA_CODEX_SEMANTIC_INACTIVITY_TIMEOUT=10m
# task 结束后是否保留执行环境，默认 false；可选 true / 1。
# MULTICA_KEEP_ENV_AFTER_TASK=false

# Daemon 自动清理默认启用。可选 false / 0 禁用。
# 默认值：GC_INTERVAL=1h、GC_TTL=24h、GC_ORPHAN_TTL=72h、GC_ARTIFACT_TTL=12h。
# 默认清理的可再生构建目录：node_modules,.next,.turbo。
# MULTICA_GC_ENABLED=true
# MULTICA_GC_INTERVAL=1h
# MULTICA_GC_TTL=24h
# MULTICA_GC_ORPHAN_TTL=72h
# MULTICA_GC_ARTIFACT_TTL=12h
# MULTICA_GC_ARTIFACT_PATTERNS=node_modules,.next,.turbo

# Agent CLI 探测：只有对应可执行文件能在 PATH 中找到时，该 provider 才会注册。
# 代码支持的 provider：claude / codex / copilot / opencode / openclaw / hermes /
# gemini / pi / cursor / kimi / kiro。
# 默认可执行文件：claude, codex, copilot, opencode, openclaw, hermes, gemini,
# pi, cursor-agent, kimi, kiro-cli。*_MODEL 留空表示使用该 CLI 自己的默认模型。
# MULTICA_CLAUDE_PATH=claude
# MULTICA_CLAUDE_MODEL=
# MULTICA_CLAUDE_ARGS=
MULTICA_CODEX_PATH=codex
MULTICA_CODEX_MODEL=
# MULTICA_CODEX_ARGS=
# MULTICA_COPILOT_PATH=copilot
# MULTICA_COPILOT_MODEL=
# MULTICA_OPENCODE_PATH=opencode
# MULTICA_OPENCODE_MODEL=
# MULTICA_OPENCLAW_PATH=openclaw
# MULTICA_OPENCLAW_MODEL=
# MULTICA_HERMES_PATH=hermes
# MULTICA_HERMES_MODEL=
# MULTICA_GEMINI_PATH=gemini
# MULTICA_GEMINI_MODEL=
# MULTICA_PI_PATH=pi
# MULTICA_PI_MODEL=
# MULTICA_CURSOR_PATH=cursor-agent
# MULTICA_CURSOR_MODEL=
# MULTICA_KIMI_PATH=kimi
# MULTICA_KIMI_MODEL=
# MULTICA_KIRO_PATH=kiro-cli
# MULTICA_KIRO_MODEL=

# 自动化失败监控：定期暂停失败率过高的自动化，并给创建者发 inbox 通知。
# 代码默认值：每 24h 扫描一次，观察过去 7 天，至少 50 次运行，失败率 > 0.9，
# 服务启动后延迟 1m 首次扫描。INTERVAL=0 可完全禁用。
# AUTOPILOT_FAIL_MONITOR_INTERVAL=24h
# AUTOPILOT_FAIL_MONITOR_LOOKBACK=168h
# AUTOPILOT_FAIL_MONITOR_MIN_RUNS=50
# AUTOPILOT_FAIL_MONITOR_FAIL_RATIO=0.9
# AUTOPILOT_FAIL_MONITOR_STARTUP_DELAY=1m

# Runtime usage 默认读原始 task_usage；设置为 "true" 后改读日聚合表。
# 只在 migrations 072..076、backfill 和 pg_cron rollup 都正常后启用。
# USAGE_DAILY_ROLLUP_ENABLED=false

# 自托管镜像渠道
# 默认使用稳定发布渠道。如需固定版本，可指定精确 release（例如 v0.2.4）。
# 如果所选 tag 尚未发布到 GHCR，请改用 just selfhost-build 或构建覆盖项。
MULTICA_IMAGE_TAG=latest
MULTICA_BACKEND_IMAGE=ghcr.io/multica-ai/multica-backend
MULTICA_WEB_IMAGE=ghcr.io/multica-ai/multica-web

# 邮件（Resend）
# 本地/开发环境可留空 RESEND_API_KEY，验证码会打印到 stdout。
# 生产环境需设置 Resend API key，并将 RESEND_FROM_EMAIL 改为 Resend 账号中
# 已验证域名下的发件地址。
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@multica.ai

# Google OAuth
# Web 登录页会在运行时从 /api/config 读取 GOOGLE_CLIENT_ID，因此修改后只需
# 重启 backend / compose stack，无需重新构建 web。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# S3 / CloudFront
# S3_BUCKET 只填写 bucket 名称（例如 "my-bucket"）。不要包含
# ".s3.<region>.amazonaws.com" 后缀；服务端会根据 S3_BUCKET + S3_REGION
# 拼出公开 URL。S3_REGION 必须与 bucket 的真实区域一致。
S3_BUCKET=
S3_REGION=us-west-2
# 可选：S3 兼容服务（如 R2/MinIO）可设置 AWS_ENDPOINT_URL；AWS S3 留空。
# 若未通过 IAM role 提供凭据，可设置标准 AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY。
# AWS_ENDPOINT_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# CloudFront 签名 cookie：CLOUDFRONT_KEY_PAIR_ID 留空则禁用。
# 启用时必须设置 CLOUDFRONT_DOMAIN，并提供私钥。生产优先使用 Secrets Manager
# 的 CLOUDFRONT_PRIVATE_KEY_SECRET；本地开发可用 base64 PEM 放到 CLOUDFRONT_PRIVATE_KEY。
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_SECRET=multica/cloudfront-signing-key
CLOUDFRONT_PRIVATE_KEY=
CLOUDFRONT_DOMAIN=
# COOKIE_DOMAIN：可选，用于设置 session 与 CloudFront cookie 的 Domain 属性。
# 单主机部署（localhost、局域网 IP 或单一 hostname）请留空，此时 session cookie
# 会成为 host-only cookie，更符合浏览器预期。只有当前端和后端位于同一注册域名
# 的不同子域时才需要设置（例如 ".example.com"）。不要设置为 IP 地址：
# RFC 6265 禁止在 cookie Domain 中使用 IP 字面量，浏览器会静默丢弃这类 cookie。
COOKIE_DOMAIN=

# 本地文件存储（未设置 S3_BUCKET 时的 fallback）
LOCAL_UPLOAD_DIR=./data/uploads
LOCAL_UPLOAD_BASE_URL=http://localhost:8080

# 安全
# CORS 与 WebSocket 允许来源列表，多个来源用英文逗号分隔。
# 留空时默认允许 localhost 开发来源；服务端也兼容旧名 CORS_ALLOWED_ORIGINS，
# 但新配置统一使用 ALLOWED_ORIGINS。
# 示例：ALLOWED_ORIGINS=https://app.multica.ai,https://staging.multica.ai
ALLOWED_ORIGINS=
# CORS_ALLOWED_ORIGINS=

# 实时指标端点（/health/realtime）访问控制。见 MUL-1342。
# 留空时，该端点只服务无转发头的 direct loopback（127.0.0.1 / ::1）请求，
# 其他请求返回 404，适合本地开发。任何位于反向代理之后的部署（例如 Caddy /
# Nginx 在 localhost:8080 前终止 TLS）都必须设置该 token，因为 Go 层看到的
# 代理请求会像 loopback；若未设置 token，这些请求会被 404 拒绝。
# 请求时使用 `Authorization: Bearer <token>`。
# REALTIME_METRICS_TOKEN=

# GitHub App 集成（设置 → 集成 → “连接 GitHub”）
# 必须同时设置以下两项，连接按钮才会启用，webhook 才会被接受。
# 留空表示禁用该集成。见 docs/github-integration。
# GITHUB_APP_SLUG 是 https://github.com/apps/<slug> 末尾的 slug。
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=
# 可选：导入 GitHub skill 时使用 bearer token，把 GitHub API rate limit
# 从匿名 60/hour 提升到 5000/hour，并支持含 slash 的 ref 解析。
# GITHUB_TOKEN=

# 前端
FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
# 建议留空：浏览器中会根据页面来源自动推导，本地开发由 Justfile 设置。
# 只有当前端和后端位于不同域名时才需要显式设置。
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=

# 远程 API（可选）：将本地前端代理到远程后端时设置。
# 留空则使用本地后端（localhost:8080）。
# REMOTE_API_URL=https://multica-api.copilothub.ai

# ==================== 自托管：注册控制（fixes #930） ====================
# 设置为 "false" 可完全禁用新用户注册，私有实例建议关闭。
# 代码只把精确字符串 "false" 视为关闭；其他值（含留空）都等价于开启。
ALLOW_SIGNUP=true
# Web UI 会在运行时从 /api/config 读取 ALLOW_SIGNUP，因此修改后只需重启
# backend / compose stack，无需重新构建 web。该配置不支持热更新。

# 可选：只允许这些邮箱域名注册（英文逗号分隔）
# 示例：example.com,company.dev
ALLOWED_EMAIL_DOMAINS=

# 可选：只允许这些完整邮箱地址注册（英文逗号分隔）
# 示例：alice@example.com,bob@example.com
ALLOWED_EMAILS=

# ==================== 数据分析（PostHog） ====================
# 产品分析事件用于获客 → 激活 → 扩展漏斗。
# 本地开发/自托管实例可留空 POSTHOG_API_KEY；服务端会使用 no-op analytics
# client，不会上报任何事件。见 docs/analytics.md。
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
# 可选：覆盖 PostHog 事件里的 `environment` 属性。
# 默认从 APP_ENV 推导，并规范化为 production / staging / dev。
# 可选输入：production/prod、staging/stage、development/dev/test/local。
ANALYTICS_ENVIRONMENT=
# 即使设置了 POSTHOG_API_KEY，也强制使用 no-op client（适用于 CI / 主动退出）。
# 可选值：true / 1；其他值都视为未禁用。
ANALYTICS_DISABLED=
